    <phoneme>d&#658;&#603;f</phoneme>
  </lexeme>
  <lexeme>
    <grapheme>Geoff Robinson</grapheme>
    <alias>Jeff Robinson</alias>
  </lexeme>

  <!-- Finance acronyms (letter-spelled) -->
  <lexeme>
