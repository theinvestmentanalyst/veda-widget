<?xml version="1.0" encoding="UTF-8"?>
<lexicon version="1.0"
         xmlns="http://www.w3.org/2005/01/pronunciation-lexicon"
         alphabet="ipa"
         xml:lang="en-GB">

  <!-- Product and brand -->
  <lexeme>
    <grapheme>InsightOne</grapheme>
    <alias>Insight One</alias>
  </lexeme>
  <lexeme>
    <grapheme>TheInvestmentAnalyst.com</grapheme>
    <alias>The Investment Analyst dot com</alias>
  </lexeme>

  <!-- Person -->
